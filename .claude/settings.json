{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash",
      "Read",
      "Write"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-restore.mjs 2>> /tmp/luca-gstack-hooks.log || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/route-guard.mjs 2>> /tmp/luca-gstack-hooks.log || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit.mjs 2>> /tmp/luca-gstack-hooks.log || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-sync.mjs 2>> /tmp/luca-gstack-hooks.log || true"
          }
        ]
      }
    ]
  }
}
