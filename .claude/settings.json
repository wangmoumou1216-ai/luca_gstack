{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash",
      "Read",
      "Write"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/session-restore.mjs\" 2>> /tmp/luca-gstack-hooks.muse.log || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROUTE_GUARD_HEAVY_SKILLS=auto,muse-loop-orchestrate node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/route-guard.mjs\" 2>> /tmp/luca-gstack-hooks.muse.log || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit|NotebookEdit|Read|Grep|Glob|Bash)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/project-scope-guard.mjs\" 2>> /tmp/luca-gstack-hooks.muse.log || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit|NotebookEdit|Bash|Task|Agent|WebFetch|WebSearch|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/post-edit.mjs\" 2>> /tmp/luca-gstack-hooks.muse.log || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/session-sync.mjs\" 2>> /tmp/luca-gstack-hooks.muse.log || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/session-end.mjs\" 2>> /tmp/luca-gstack-hooks.muse.log || true"
          }
        ]
      }
    ]
  }
}
